{
  "manifest_version": 3,
  "name": "Inner Peace",
  "version": "1.2.0",
  "description": "Redirects distracting sites to a calm breathing space with gentle nature sounds. Configurable block list.",
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["*://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Open your calm space",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "calm.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    { "resources": ["calm.html"], "matches": ["<all_urls>"] }
  ]
}
