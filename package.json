{
  "name": "inner-peace",
  "version": "1.2.0",
  "private": true,
  "description": "A browser extension that redirects distracting sites to a calm breathing space.",
  "scripts": {
    "test:unit": "node --test test/unit",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "pretest:e2e": "playwright install chromium",
    "record:gifs": "node tools/record-gifs.js",
    "record:redirect": "node tools/record-redirect-live.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "ffmpeg-static": "^5.3.0"
  }
}
